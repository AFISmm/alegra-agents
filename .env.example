# Credenciales de Alegra
ALEGRA_USER=correo@empresa.com
ALEGRA_TOKEN=tu_token_api_de_alegra

# URL base de la API (no modificar salvo cambio de versión)
ALEGRA_API_BASE=https://api.alegra.com/api/v1

# Carpetas de datos
TRANSACTIONS_FOLDER=data/transactions
TEMPLATES_OUTPUT_FOLDER=data/templates

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Forzar salida sin buffer (requerido en Python 3.14+ para ver logs en tiempo real)
PYTHONUNBUFFERED=1
